# Copy to .env and adjust. All values are optional — the app runs with defaults.

# Anthropic API key — OPTIONAL.
# When absent, the Talk (conversation) tab is disabled and everything else works.
ANTHROPIC_API_KEY=

# Whisper model for pronunciation scoring (Phase 4). tiny|base|small|medium.
WHISPER_MODEL=small

# Port the single FastAPI process listens on (serves API + built frontend).
# Spec's canonical default is 3170; this project currently runs on 3002.
PORT=3002

# Host to bind. 0.0.0.0 so Tailscale Serve / your phone can reach it.
HOST=0.0.0.0
